{
  auto_https off
}

:{$PORT} {
  log {
    output stdout
    format console
  }

  handle /health {
    respond "gateway ok" 200
  }

  handle_path /auth/* {
    reverse_proxy auth.railway.internal:8001
  }
  handle_path /profile/* {
    reverse_proxy profile.railway.internal:8002
  }
  handle_path /symptoms/* {
    reverse_proxy symptom.railway.internal:8003
  }
  handle_path /chat/* {
    reverse_proxy chat.railway.internal:8004
  }
  handle_path /tracker/* {
    reverse_proxy tracker.railway.internal:8005
  }
  handle_path /notifications/* {
    reverse_proxy notification.railway.internal:8006
  }
  handle_path /agent/* {
    reverse_proxy agent.railway.internal:8007
  }
  handle_path /billing/* {
    reverse_proxy billing.railway.internal:8008
  }
  handle_path /data/* {
    reverse_proxy data.railway.internal:8009
  }

  handle {
    respond "Not Found" 404
  }
}
