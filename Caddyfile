{
  auto_https off
}

:{$PORT} {

  log {
    output stdout
    format json
  }

  #################################################################
  # CORS
  #################################################################

  @cors_preflight method OPTIONS
  handle @cors_preflight {
    header Access-Control-Allow-Origin "https://safeborn.app"
    header Access-Control-Allow-Credentials "true"
    header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    header Access-Control-Allow-Headers "Authorization, Content-Type, Accept"
    header Access-Control-Max-Age "3600"
    respond "" 204
  }

  header {
    Access-Control-Allow-Origin "https://safeborn.app"
    Access-Control-Allow-Credentials "true"
    -Server
  }

  #################################################################
  # AUTH PROXY SNIPPET
  #################################################################

  (auth_proxy) {
    header_up Authorization {header.Authorization}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Real-IP {remote}
    header_up X-Forwarded-For {remote}
    header_up Host {host}
  }

  #################################################################
  # ROUTES
  #################################################################

  handle /health {
    respond "gateway ok" 200
  }

  handle_path /auth/* {
    reverse_proxy auth.railway.internal:8001
  }

  handle /profile* {
    reverse_proxy profile.railway.internal:8002 {
      import auth_proxy
    }
  }

  handle /symptoms* {
    reverse_proxy symptom.railway.internal:8003 {
      import auth_proxy
    }
  }

  handle /chat* {
    reverse_proxy chat.railway.internal:8004 {
      import auth_proxy
    }
  }

  handle /tracker* {
    reverse_proxy tracker.railway.internal:8005 {
      import auth_proxy
    }
  }

  handle /notifications* {
    reverse_proxy notification.railway.internal:8006 {
      import auth_proxy
    }
  }

  handle /agent* {
    reverse_proxy agent.railway.internal:8007 {
      import auth_proxy
    }
  }

  handle /billing* {
    reverse_proxy billing.railway.internal:8008 {
      import auth_proxy
    }
  }

  handle /data* {
    reverse_proxy data.railway.internal:8009 {
      import auth_proxy
    }
  }

  handle /content* {
    reverse_proxy content.railway.internal:8010 {
      import auth_proxy
    }
  }

  handle {
    respond "Not Found" 404
  }
}